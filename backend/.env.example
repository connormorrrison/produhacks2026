APP_NAME=CareCircle Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# Local Postgres for development. Update this when you move to a hosted DB.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/checkin
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=ca-central-1
S3_BUCKET_NAME=replace-me
S3_RECORDINGS_PREFIX=sessions
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-1.5-pro
HEYGEN_API_KEY=replace-me
HEYGEN_BASE_URL=https://api.heygen.com
TWILIO_ACCOUNT_SID=replace-me
TWILIO_AUTH_TOKEN=replace-me
TWILIO_FROM_PHONE_NUMBER=+10000000000
FIREBASE_PROJECT_ID=replace-me
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=replace-me@replace-me.iam.gserviceaccount.com
FRONTEND_BASE_URL=http://localhost:3000
